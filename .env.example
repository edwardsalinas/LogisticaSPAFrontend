# ========================================
# CONFIGURACIÓN DEL FRONTEND
# ========================================

# URL de la API del Backend
VITE_API_URL=http://localhost:3000/api

# ========================================
# MODO DE DESARROLLO
# ========================================
# true = Usa datos mock (desarrollo frontend sin backend)
# false = Usa API real (producción o testing con backend)
VITE_USE_MOCKS=true

# ========================================
# CONFIGURACIÓN DE MAPAS (Opcional)
# ========================================
# Si quieres usar Mapbox en lugar de Leaflet/OSM:
# VITE_MAPBOX_TOKEN=pk.eyJ1Ijoi...

# ========================================
# CONFIGURACIÓN DE AUTH (Opcional)
# ========================================
# VITE_AUTH_ENABLED=true
# VITE_SESSION_TIMEOUT=3600000
